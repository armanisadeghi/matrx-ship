{
  "name": "matrx-manager",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "dotenv -e .env.local -- node --watch src/index.js",
    "generate-token": "openssl rand -hex 32",
    "show-token": "dotenv -e .env.local -- node -e \"console.log('Current token:', process.env.MANAGER_TOKENS || 'Not set')\""
  },
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-ecr": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2"
  }
}
