# Database
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://ship:${POSTGRES_PASSWORD}@db:5432/ship

# Host port (useful when running multiple instances on one server)
PORT=3000

# API Key for CLI and client authentication
# Generated automatically on first boot if not set
MATRX_SHIP_API_KEY=

# Admin secret — operator break-glass sign-in for the admin portal. Optional
# when OAuth (below) is configured; accepted via the "operator secret" login.
MATRX_SHIP_ADMIN_SECRET=

# ── Admin OAuth (AI Matrx / Supabase) ────────────────────────────────────────
# The admin portal requires a signed-in AI Matrx admin. The browser logs in via
# the aidream OAuth broker; the Ship app re-verifies the Supabase JWT and checks
# public.admins. All three SUPABASE_MATRIX_* values are required to enable OAuth.
# When none of these and no MATRX_SHIP_ADMIN_SECRET are set, the admin API fails
# closed in production (open only in development).
SUPABASE_MATRIX_JWT_SECRET=
SUPABASE_MATRIX_URL=
SUPABASE_MATRIX_KEY=
# OAuth broker base URL (defaults to https://server.app.matrxserver.com).
MATRX_AIDREAM_URL=

# Project metadata
PROJECT_NAME=my-project

# Vercel integration (optional)
VERCEL_ACCESS_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=

# GitHub integration (optional)
GITHUB_WEBHOOK_SECRET=
